CC := gcc
CFLAGS := -Wall -Wextra -O2 -ffreestanding -fno-builtin
LDFLAGS := -nostartfiles -nodefaultlibs -Wl,-e,wWinMainCRTStartup
LDLIBS := -lshell32 -lole32 -lkernel32

TARGET := open.exe
SRCS := open.c
OBJS := $(SRCS:.c=.o)

.PHONY: all clean

all: $(TARGET)

$(TARGET): $(OBJS)
	$(CC) $(LDFLAGS) -o $@ $^ $(LDLIBS)

%.o: %.c
	$(CC) $(CFLAGS) -c -o $@ $<

clean:
	rm -f $(TARGET) $(OBJS)
